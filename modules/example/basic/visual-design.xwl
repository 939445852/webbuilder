    text: button1
  - _icon: label
    cls: Wb.Label
    properties:
      cid: label1
      html: |-
        <ol>
          <li>Select container control that requires visual design, such as click viewport1 node.</li>
          <li>Click the [UI Designer] button on the toolbar to launch the visual layout designer.</li>
          <li>Drag the control(or double click/Ctrl + double click) from the control tree to the designer.</li>
          <li>Drag the control to adjust its position.</li>
        </ol>
    text: label1
  properties:
    cid: viewport1
    layout: grid1
  text: viewport1
