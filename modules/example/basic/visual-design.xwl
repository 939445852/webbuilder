_expanded: true
_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
items:
- _expanded: true
  _icon: viewport
  cls: Wb.Viewport
  items:
  - _icon: text
    cls: Wb.Text
    properties:
      cid: text1
      text: text1
    text: text1
  - _icon: number-edit
    cls: Wb.Number
    properties:
      cid: number1
      text: number1
    text: number1
  - _expanded: false
    _icon: button
    cls: Wb.Button
    properties:
      cid: button1
