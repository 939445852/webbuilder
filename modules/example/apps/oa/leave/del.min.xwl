  serverScript: function main(){const e=Wb.load("./util.mjs");Params.flowId=Wb.getObject("del").$flow_id;Wb.startTrans();e.checkProcess();Wb.sql("delete
    from wb_flow where sid={?flowId?}");Wb.sql("delete from wb_flow_user where flow_id={?flowId?}");Wb.sql("delete
    from wb_leave where flow_id={?flowId?}")}main();
