_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
properties:
  cid: module
  serverScript: |-
    function main() {
      let sql;

      sql = 'select a.*,b.title,b.node_text from wb_leave a, wb_flow b where a.flow_id=b.sid and a.user_id={?sys.userid?}';
      sql += Wb.getOrderSql({ title: 'b.title', node_text: 'b.node_text' });
      Wb.sendRowx(sql);
    }
    main();
tags: ''
text: module
title: ''
