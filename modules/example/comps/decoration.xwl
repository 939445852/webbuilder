  - _expanded: true
    _icon: title
    cls: Wb.Title
    properties:
      cid: compTitle
      title: Component
    text: compTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: component
      cls: Wb.Component
      properties:
        autoScroll: 'true'
        border: 'true'
        cid: component1
        cls: w-key-color
        height: 7em
        html: Component is a "div" element that can show HTML or serve as a placeholder
          for third-party components.
        padding: 'true'
        width: 25em
      text: component1
    - _icon: file-json
      cls: Wb.Script
      properties:
        cid: script1
        script: '({ cname: ''component'', html: ''<div>Custom script</div>'' })'
      text: script1
    properties:
      cid: compCt
      frame: 'true'
      layout: form
    text: compCt
  properties:
