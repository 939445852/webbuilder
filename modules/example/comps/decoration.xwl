_expanded: true
_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: label
img: ''
items:
- _expanded: true
  _icon: viewport
  cls: Wb.Viewport
  items:
  - _icon: label
    cls: Wb.Label
    properties:
      cid: mainLabel
      cls: w-title3
      text: Label and decorative components
    text: mainLabel
  - _expanded: true
    _icon: title
    cls: Wb.Title
    properties:
      cid: labelTitle
      title: Label
    text: labelTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: label
      cls: Wb.Label
      properties:
        cid: textLabel
        text: Text label
      text: textLabel
    - _icon: label
      cls: Wb.Label
      properties:
        cid: htmlLabel
        html: HTML <span class="w-error-color">label</span>
      text: htmlLabel
    - _icon: label
      cls: Wb.Label
      properties:
        cid: linkLabel
        href: https://www.geejing.com
        target: _blank
        text: Link label
      text: linkLabel
    properties:
      cid: labelCt
      frame: 'true'
      layout: form
    text: labelCt
  - _expanded: true
    _icon: title
    cls: Wb.Title
    properties:
      cid: boxLabelTitle
      title: BoxLabel
    text: boxLabelTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: box-label
      cls: Wb.BoxLabel
      properties:
        cid: centerLabel
        frame: 'true'
        text: Center
      text: centerLabel
    - _icon: box-label
      cls: Wb.BoxLabel
      properties:
        align: topLeft
        cid: topLeftLabel
        frame: 'true'
        text: Top left
      text: topLeftLabel
    - _icon: box-label
      cls: Wb.BoxLabel
      properties:
        align: bottomRight
        cid: bottomRightLabel
        frame: 'true'
        text: Bottom right
      text: bottomRightLabel
    properties:
      cid: boxLabelCt
      defaults: '({ width: ''10em'', height: ''5em'' })'
      frame: 'true'
      layout: form
    text: boxLabelCt
  - _expanded: true
    _icon: title
    cls: Wb.Title
    properties:
      cid: breadcrumbTitle
      title: Breadcrumb
    text: breadcrumbTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: right3
      cls: Wb.Breadcrumb
      events:
        itemclick: 'Wb.tip(''Clicked: '' + Wb.encode(item) + '', index: '' + index);'
      properties:
        cid: breadcrumb1
        items: '[''Item1'', { text: ''Item2'', id: ''myId'' }, ''Item3'', 123]'
      text: breadcrumb1
    properties:
      cid: breadcrumbCt
      frame: 'true'
      layout: form
    text: breadcrumbCt
  - _expanded: true
    _icon: title
    cls: Wb.Title
    properties:
      cid: decTitle
      title: Decorative components
    text: decTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _expanded: true
      _icon: title
      cls: Wb.Title
      properties:
        cid: commonTitle
        title: Title
      text: commonTitle
    - _expanded: true
      _icon: title
