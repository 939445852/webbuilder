      cls: Wb.Button
      events:
        click: Wb.toast('Some information');
      properties:
        cid: infoBtn
        text: Info
      text: infoBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.toast('<span class="w-error-color">HTML information</span>', true);
      properties:
        cid: htmlInfoBtn
        text: HTML tip
      text: htmlInfoBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.toastSucc('Some information');
      properties:
        cid: succBtn
        text: Succ
      text: succBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.toastWarn('Some information');
      properties:
        cid: warnBtn
        text: Warn
      text: warnBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.toastError('Some information');
      properties:
        cid: errorBtn
        text: Error
      text: errorBtn
    properties:
      cid: toastCt
      frame: 'true'
      layout: form
    text: toastCt
  - _icon: title
    cls: Wb.Title
    properties:
      cid: dialogTitle
      title: Dialog
    text: dialogTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: button
      cls: Wb.Button
      events:
        click: app.normalDialog.show();
      properties:
        cid: normalBtn
        text: Normal dialog
      text: normalBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: app.customDialog.show();
      properties:
        cid: customBtn
        text: Custom dialog
      text: customBtn
    properties:
      cid: dialogCt
      frame: 'true'
      layout: form
    text: dialogCt
  - _icon: title
    cls: Wb.Title
    properties:
      cid: drawerTitle
      title: Drawer
    text: drawerTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: button
      cls: Wb.Button
      events:
        click: app.defaultDrawer.show();
      properties:
        cid: defaultBtn
        text: Default drawer
      text: defaultBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: |-
          app.topDrawer ??= new Wb.Drawer({ dockPosition: 'top', height: '40vh', title: 'Top Drawer', plainTitle: true });
          app.topDrawer.show();
      properties:
        cid: topBtn
        text: Top drawer
      text: topBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: app.rightDrawer.show();
      properties:
        cid: rightBtn
        text: Right drawer
      text: rightBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: |-
          app.leftDrawer ??= new Wb.Drawer({ dockPosition: 'left', width: '40vw', title: 'Left Drawer' });
          app.leftDrawer.show();
      properties:
        cid: leftBtn
        text: Left drawer
      text: leftBtn
    properties:
      cid: drawerCt
      frame: 'true'
      layout: form
    text: drawerCt
  - _icon: title
    cls: Wb.Title
    properties:
      cid: promptTitle
      title: Prompt Window
    text: promptTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: button
      cls: Wb.Button
      events:
        click: |-
          Wb.promptString('Enter String', (text, win) => {
            Wb.tip('Enter "' + text + '".');
            win.close();
          }, 'old string');
      properties:
        cid: promptStringBtn
        text: Prompt string
      text: promptStringBtn
    - _expanded: true
      _icon: button
      cls: Wb.Button
      events:
        click: |-
          Wb.promptText('Enter Text', (text, win) => {
            Wb.tip('Enter "' + text + '".');
            win.close();
          }, 'old text');
      properties:
        cid: promptTextBtn
        text: Prompt text
      text: promptTextBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: |-
          Wb.prompt('My Dialog', [
            { text: 'Your Name', cid: 'name', value: 'old value' },
            { text: 'Date', cid: 'date', cname: 'date' }
          ], (values, win) => {
            Wb.tip(Wb.encode(values));
            win.close();
          });
      properties:
        cid: customPromptBtn
        text: Custom prompt
      text: customPromptBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: |-
          let win = Wb.prompt({ title: 'My Single Dialog', icon: 'chart-bar'/*, resetDialog: true*/ }, [
            { text: 'Your Name', cid: 'name', value: 'old value' },
            { text: 'Date', cid: 'date', cname: 'date' }
          ], (values, win) => {
            Wb.tip(Wb.encode(values));
            win.close();
          }, 'my.win.id');
          // Wb.reset(win);
      properties:
        cid: singleInstanceBtn
        text: Single instance
      text: singleInstanceBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.hover(app.hoverPanel, this);
      properties:
        cid: hoverPanelBtn
        text: Hover panel
      text: hoverPanelBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: |-
          Wb.hover(app.hideGetValuePanel, this, panel => {
            Wb.tip(Wb.encode(Wb.getValue(panel)));
          });
      properties:
        cid: hideGetValueBtn
        text: Hide to get value
      text: hideGetValueBtn
    properties:
      cid: promptCt
      frame: 'true'
      layout: form
    text: promptCt
  - _icon: title
    cls: Wb.Title
    properties:
      cid: tooltipTitle
      title: Tooltip
    text: tooltipTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: component
      cls: Wb.Component
      properties:
        cid: tipComp
        frame: 'true'
        padding: 1em
        text: Move the mouse here
        tip: Common tip message
      text: tipComp
    - _icon: component
      cls: Wb.Component
      properties:
        cid: retainTipComp
        frame: 'true'
        padding: 1em
        text: Retain tip
        tip: '{enterRetain: true, textSelectable: true, html: ''When the pointer is
          in the Tip, it will not auto hide.''}'
      text: retainTipComp
    - _expanded: false
      _icon: component
      cls: Wb.Component
      items:
      - _expanded: true
        _icon: info
        cls: Wb.Tip
        items:
        - _icon: label
          cls: Wb.Label
          properties:
            cid: label1
            text: Some descriptions
            titleType: title4
          text: label1
        - _icon: text
          cls: Wb.Text
          properties:
            cid: text1
            text: Text
          text: text1
        - _icon: number-edit
          cls: Wb.Number
          properties:
            cid: number1
            text: Number
          text: number1
        - _icon: label1
          cls: Wb.DisplayField
          properties:
            cid: displayField1
            text: Display Field
            value: Some value
          text: displayField1
        - _icon: button
          cls: Wb.Button
          properties:
            cid: button1
            icon: button
            text: Button
          text: button1
        properties:
          cid: tip
          enterRetain: 'true'
          frame: 'true'
          gap: 1em
          isProperty: 'true'
          layout: grid1
          width: 40em
        text: tip
      properties:
        cid: customTip
        frame: 'true'
        padding: 1em
        text: Custom retain tip
      text: customTip
    - _expanded: true
      _icon: component
      cls: Wb.Component
      properties:
        cid: customShareTip1
        frame: 'true'
        padding: 1em
        text: Custom share tip 1
        tip: '@app.myShareTip'
      text: customShareTip1
    - _expanded: true
      _icon: component
      cls: Wb.Component
      properties:
        cid: customShareTip2
        frame: 'true'
        padding: 1em
        text: Custom share tip 2
        tip: '@app.myShareTip'
      text: customShareTip2
    - _icon: component
      cls: Wb.Component
      events:
        click: Wb.tipAt('Some message', e.x, e.y);
      properties:
        cid: clickToTipComp
        frame: 'true'
        padding: 1em
        text: Click to tip
      text: clickToTipComp
    properties:
      cid: tooltipCt
      frame: 'true'
      layout: form
    text: tooltipCt
  properties:
    cid: viewport1
    layout: grid1
  text: viewport1
properties:
  cid: module
tags: ''
text: module
title: ''
