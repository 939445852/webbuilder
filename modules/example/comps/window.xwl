_expanded: true
_icon: module
cls: Wb.Module
events:
  initialize: |-
    Wb.apply(app, {
      //Define Share tip
      myShareTip: new Wb.Tip({
        cls: 'w-error-color', fontSize: '1.5em', padding: '.2em', events: {
          beforetip(comp) {
            this.text = 'My share tip: ' + comp.cid;
          }
        }
      })
    });
hideInMenu: 'false'
icon: window
img: ''
items:
- _expanded: true
  _icon: array
  cls: Wb.Array
  items:
  - _expanded: false
    _icon: window
    cls: Wb.Window
    items:
    - _icon: text
      cls: Wb.Text
      properties:
        cid: text1
        text: Your name
      text: text1
    - _expanded: true
      _icon: calendar
      cls: Wb.Date
      properties:
        cid: date1
        text: Birth date
      text: date1
    properties:
      cid: dynamicNewWin
      closeAction: destroy
      instanced: 'false'
      layout: grid1
      title: Dynamic window
    text: dynamicNewWin
  - _expanded: false
    _icon: window
    cls: Wb.Window
    items:
    - _icon: text
      cls: Wb.Text
      properties:
        cid: text1
        text: Your name
      text: text1
    - _expanded: true
      _icon: calendar
      cls: Wb.Date
      properties:
        cid: date1
        text: Birth date
      text: date1
    properties:
      cid: modalWin
      icon: bluetooth1
      layout: grid1
      modal: 'true'
      title: Modal window
    text: modalWin
  - _expanded: false
    _icon: window
    cls: Wb.Window
    items:
    - _icon: label
      cls: Wb.Label
      properties:
        cid: label1
        text: The values of all controls will be automatically reset after the window
          is hidden
      text: label1
    - _expanded: true
      _icon: text
      cls: Wb.Text
      properties:
        cid: text1
        text: Your name
      text: text1
    - _icon: text
      cls: Wb.Text
      properties:
        cid: text2
        text: Default value
        value: abc
      text: text2
    - _expanded: true
      _icon: calendar
      cls: Wb.Date
      properties:
        cid: date1
        text: Birth date
      text: date1
    properties:
      cid: autoResetWin
      icon: bluetooth1
      layout: grid1
      resetDialog: 'true'
      title: Auto reset window
    text: autoResetWin
  - _expanded: false
    _icon: dialog
    cls: Wb.Dialog
    items:
    - _expanded: true
      _icon: options
      cls: Wb.Option
      events:
        click: app.customDialog.show();
      properties:
        cid: showDialogOption
        text: Show custom dialog
      text: showDialogOption
    properties:
      cid: normalDialog
      title: Normal Dialog
    text: normalDialog
  - _expanded: false
    _icon: dialog
    cls: Wb.Dialog
    items:
    - _icon: text
      cls: Wb.Text
      properties:
        cid: text1
        text: Your name
      text: text1
    - _expanded: true
      _icon: calendar
      cls: Wb.Date
      properties:
        cid: date1
        text: Birth date
      text: date1
    - _icon: button
      cls: Wb.Button
      events:
        click: app.newDialog.show();
      properties:
        cid: newDialog
        text: New Dialog
        type: primary
      text: newDialog
    - _expanded: true
      _icon: array
      cls: Wb.Array
      items:
      - _expanded: true
        _icon: item
        cls: Wb.Item
        events:
          click: Wb.tip(Str.set);
        properties:
          cid: item1
          icon: gear
        text: item1
      properties:
        cid: tools
      text: tools
    - _expanded: true
      _icon: menu2
      cls: Wb.Menu
      items:
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item1
          icon: add
          text: '@Str.add'
        text: item1
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item2
          icon: edit
          text: '@Str.edit'
        text: item2
      - _expanded: false
        _icon: item
        cls: Wb.Item
        properties:
          cid: item3
          icon: delete
          text: '@Str.del'
        text: item3
      properties:
        cid: menu
        isProperty: 'true'
      text: menu
    properties:
      cid: customDialog
      labelUp: 'true'
      layout: grid1
      plainTitle: 'false'
      title: Custom Dialog
      titleCenter: 'false'
    text: customDialog
  - _expanded: true
    _icon: dialog
    cls: Wb.Dialog
    properties:
      cid: newDialog
      layout: grid1
      title: New Dialog
    text: newDialog
  - _expanded: false
    _icon: drawer
    cls: Wb.Drawer
    items:
    - _expanded: true
      _icon: toolbar
      cls: Wb.Toolbar
      items:
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item1
          icon: add
          iconAlign: top
          iconSize: 2em
          text: Item1
        text: item1
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item2
          icon: edit
          iconAlign: top
          iconSize: 2em
          text: Item2
        text: item2
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item3
          icon: delete
          iconAlign: top
          iconSize: 2em
          text: Item3
        text: item3
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item4
          icon: book1
          iconAlign: top
          iconSize: 2em
          text: Item4
        text: item4
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item5
          icon: discovery
          iconAlign: top
          iconSize: 2em
          text: Item5
        text: item5
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item6
          icon: comment2
          iconAlign: top
          iconSize: 2em
          text: Item6
        text: item6
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item7
          icon: flow1
          iconAlign: top
          iconSize: 2em
          text: Item7
        text: item7
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item8
          icon: dict
          iconAlign: top
          iconSize: 2em
          text: Item8
        text: item8
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item9
          icon: grid
          iconAlign: top
          iconSize: 2em
          text: Item9
        text: item9
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item10
          icon: layout
          iconAlign: top
          iconSize: 2em
          text: Item10
        text: item10
      - _icon: line
        cls: Wb.Line
        properties:
          cid: line1
          title: My Title
        text: line1
      - _expanded: true
        _icon: text
        cls: Wb.Text
        properties:
          cid: text1
          gridColumn: span 5
          text: Input text
        text: text1
      - _icon: switcher-on
        cls: Wb.Toggle
        properties:
          cid: toggle1
          gridColumn: span 5
          text: Toggle
        text: toggle1
      properties:
        cid: toolbar1
        layout: grid5
        vertical: 'true'
      text: toolbar1
    - _expanded: true
      _icon: array
      cls: Wb.Array
      items:
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item1
          icon: gear
        text: item1
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item2
          icon: share
        text: item2
      properties:
        cid: tools
      text: tools
    properties:
      cid: defaultDrawer
      closable: 'true'
      focusControl: 'false'
      icon: fieldset
      layout: fit
      title: Default Drawer
    text: defaultDrawer
  - _expanded: false
    _icon: drawer
    cls: Wb.Drawer
    items:
    - _expanded: true
      _icon: toolbar
      cls: Wb.Toolbar
      events:
        buttonclick: |-
          Wb.tip(button.text + ' clicked');
          this.parent.close();
      items:
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item1
          icon: favorite
          text: Favorite Pages
        text: item1
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item2
          icon: gear
          text: Setting
        text: item2
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item3
          icon: command
          text: Command
        text: item3
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item4
          icon: word
          text: Export to Word
        text: item4
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item5
          icon: excel
          text: Export to Excel
        text: item5
      - _icon: divider
        cls: Wb.Divider
        properties:
          cid: divider1
        text: divider1
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item6
          icon: print
          text: Print
        text: item6
      - _expanded: true
        _icon: item
        cls: Wb.Item
        properties:
          cid: item7
          icon: table
          text: Show Table
        text: item7
