        cid: toolbar1
        type: menu
      text: toolbar1
    properties:
      cid: rightDrawer
      dockPosition: right
      layout: fit
      title: Right Drawer
    text: rightDrawer
  - _expanded: false
    _icon: panel
    cls: Wb.Panel
    items:
    - _expanded: true
      _icon: text
      cls: Wb.Text
      properties:
        cid: text1
        text: User name
      text: text1
    - _expanded: true
      _icon: calendar
      cls: Wb.Date
      properties:
        cid: date1
        text: Date
      text: date1
    - _expanded: true
      _icon: array
      cls: Wb.Array
      items:
      - _expanded: true
        _icon: button
        cls: Wb.Button
        events:
          click: |-
            let panel = this.up('hoverPanel');
            Wb.tip(Wb.encode(Wb.getValue(panel)));
            panel.hide();
        properties:
          cid: button1
          icon: ok
          text: OK
          type: primary
        text: button1
      - _expanded: true
        _icon: button
        cls: Wb.Button
        events:
          click: this.up('hoverPanel').hide();
        properties:
          cid: button2
          icon: cancel
          text: Cancel
        text: button2
      properties:
        cid: buttons
      text: buttons
    properties:
      cid: hoverPanel
      layout: grid1
      minButtonWidth: 8em
      visible: 'false'
    text: hoverPanel
  - _expanded: false
    _icon: panel
    cls: Wb.Panel
    items:
    - _expanded: true
      _icon: text
      cls: Wb.Text
      properties:
        cid: text1
        text: User name
      text: text1
    - _expanded: true
      _icon: calendar
      cls: Wb.Date
      properties:
        cid: date1
        text: Date
      text: date1
    properties:
      cid: hideGetValuePanel
      layout: grid1
      minButtonWidth: 8em
      tagProperties: '({ closeOnEsc: false })'
      visible: 'false'
    text: hideGetValuePanel
  properties:
    cid: components
  text: components
- _expanded: true
  _icon: viewport
  cls: Wb.Viewport
  items:
  - _expanded: true
    _icon: label
    cls: Wb.Label
    properties:
      cid: mainLabel
      cls: w-title3
      text: Window and Tip
    text: mainLabel
  - _expanded: true
    _icon: title
    cls: Wb.Title
    properties:
      cid: winTitle
      title: Window List
    text: winTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: button
      cls: Wb.Button
      events:
        click: |-
          let win = app.dynamicNewWin;

          delete win.cid; //Prevent conflicts with the instance cid
          win.owner = parentContainer; //make the win automatically destroy when parentContainer is destroyed

          //You can render the win to winCt by the following code:
          //win.renderEl = app.winCt.el; //Render to winCt, default render to BodyEl

          win.x = Wb.random(70) + 'vw';
          win.y = Wb.random(70) + 'vh';
          win = Wb.create(win);
          win.show();
      properties:
        cid: dynamicNewWinBtn
        text: Dynamic new window
      text: dynamicNewWinBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: app.modalWin.show();
      properties:
        cid: showModalWinBtn
        text: Show modal window
      text: showModalWinBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: app.autoResetWin.show();
      properties:
        cid: showAutoResetWinBtn
        text: Show auto reset window
      text: showAutoResetWinBtn
    - _expanded: true
      _icon: window
      cls: Wb.Window
      events:
        hide: |-
          Wb.tip('Show again after 2 secs.')
          setTimeout(f => app.normalWin.show().el.fadeIn(), 2000);
      properties:
        cid: normalWin
        height: 10em
        html: Hide on Close
        icon: edit
        layout: center
        title: Normal window
        visible: 'true'
        width: 20em
      text: normalWin
    - _expanded: true
      _icon: window
      cls: Wb.Window
      events:
        destroy: Wb.tip(this.cid + ' is destroyed.');
        ok: |-
          Wb.tip('You click "' + Str.ok + '" button.');
          // Close the window after performing asynchronous operation
          // let me = this;
          // Wb.ajax({
          //   url,
          //   success(resp) {
          //     me.close();
          //   }
          // });
      properties:
        cid: dialogWin
        closeAction: destroy
        collapsible: 'true'
        dialog: 'true'
        height: 10em
        html: Destroy on Close
        layout: center
        modal: 'false'
        title: Dialog window without modal
        visible: 'true'
        width: 20em
        x: 23em
      text: dialogWin
    - _expanded: false
      _icon: window
      cls: Wb.Window
      items:
      - _icon: line
        cls: Wb.Line
        properties:
          cid: line1
          dimTitle: 'true'
          title: No title window
        text: line1
      - _icon: text
        cls: Wb.Text
        properties:
          cid: text1
          text: Your name
        text: text1
      properties:
        cid: noTitleWin
        labelUp: 'true'
        layout: grid1
        titleBar: 'false'
        visible: 'true'
        x: 45em
      text: noTitleWin
    properties:
      cid: winCt
      cls: w-rel
      frame: 'true'
      height: 20em
      layout: form
    text: winCt
  - _icon: title
    cls: Wb.Title
    properties:
      cid: messageTitle
      title: Message
    text: messageTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.info('Some information', f => Wb.tip('do something after show message'));
      properties:
        cid: infoBtn
        text: Info
      text: infoBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.info('<span class="w-error-color">HTML information</span>', null,
          true);
      properties:
        cid: htmlInfoBtn
        text: HTML Info
      text: htmlInfoBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.succ('Some information');
      properties:
        cid: succBtn
        text: Succ
      text: succBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.warn('Some information');
      properties:
        cid: warnBtn
        text: Warn
      text: warnBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.error('Some information');
      properties:
        cid: errorBtn
        text: Error
      text: errorBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.confirm('Are you sure you want to delete?', f => Wb.tip('click OK'),
          f => Wb.tip('click Cancel'));
      properties:
        cid: confirmBtn
        text: Confirm
      text: confirmBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.choose('Are you sure you want to save?', button => Wb.tip(button));
      properties:
        cid: chooseBtn
        text: Choose
      text: chooseBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: |-
          Wb.Window.showMessage({
            title: 'Customize', text: 'Some message', icon: 'share',
            name: 'sys.dialog', //name for shareing one dialog,
            buttons: [
              // The first button is the default enter button (press Enter to do), for more details see enterButton docs.
              { text: 'Primary', type: 'primary', cid: 'primary' },
              // The last button is the default esc button (press ESC or close dialog to do), for more details see escButton docs.
              { text: Str.cancel, cid: 'cancel' }
            ], callback(btn) {
              this.close();
              Wb.tip(btn + ' clicked');
            }
          });
      properties:
        cid: customizeBtn
        text: Customize
      text: customizeBtn
    - _expanded: true
      _icon: button
      cls: Wb.Button
      events:
        click: Wb.error('Some message').el.fadeIn();
      properties:
        cid: fadeAnimateBtn
        text: Fade Animate
      text: fadeAnimateBtn
    - _expanded: true
      _icon: button
      cls: Wb.Button
      events:
        click: |-
          Wb.info('Some message', function () {
            this.show().el.slideOut({ callback: f => this.hide() });
          }).el.slideIn();
      properties:
        cid: slideAnimateBtn
        text: Slide Animate
      text: slideAnimateBtn
    properties:
      cid: messageCt
      frame: 'true'
      layout: form
    text: messageCt
  - _icon: title
    cls: Wb.Title
    properties:
      cid: tipTitle
      title: Tip
    text: tipTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
    items:
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.tip('Some information');
      properties:
        cid: infoBtn
        text: Info
      text: infoBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.tip('<span class="w-error-color">HTML information</span>', true);
      properties:
        cid: htmlInfoBtn
        text: HTML tip
      text: htmlInfoBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.tipSucc('Some information');
      properties:
        cid: succBtn
        text: Succ
      text: succBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.tipWarn('Some information');
      properties:
        cid: warnBtn
        text: Warn
      text: warnBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.tipError('Some information');
      properties:
        cid: errorBtn
        text: Error
      text: errorBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.tipSelect();
      properties:
        cid: tipSelectBtn
        text: Tip Select
      text: tipSelectBtn
    - _icon: button
      cls: Wb.Button
      events:
        click: Wb.tipDone(Str.save);
      properties:
        cid: tipDoneBtn
        text: Tip Done
      text: tipDoneBtn
    properties:
      cid: tipCt
      frame: 'true'
      layout: form
    text: tipCt
  - _icon: title
    cls: Wb.Title
    properties:
      cid: toastTitle
      title: Toast
    text: toastTitle
  - _expanded: true
    _icon: container
    cls: Wb.Container
