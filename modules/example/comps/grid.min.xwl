    grid",cid:"editableGridTitle"},{cname:"grid",enterAppend:true,arrowDownAppend:true,columnsSortable:true,editable:true,pageSize:10,enterAsTab:true,sorters:[{name:"gender",desc:true},"salary"],url:"demo-source?xaction=staffAllDict",cid:"editableGrid",frame:true,height:"15em",multiSelect:true,tbar:{cname:"toolbar",items:[{icon:"add",text:Str.add,keys:"Ctrl+E",cid:"addBtn",events:{click(e,t){app.editableGrid.addRecord()}}},{icon:"edit",text:Str.edit,keys:"Ctrl+J",cid:"editBtn",events:{click(e,t){let
    a=app.editableGrid.firstItem;if(a){a.set({code:"code",full_name:"new name"});app.editableGrid.startEdit(a,"code");a.highlight()}}}},{icon:"delete",text:Str.del,keys:"Ctrl+D",cid:"delBtn",events:{click(e,t){app.editableGrid.delRecords()}}},{cname:"divider",cid:"divider1"},{icon:"save",text:Str.save,keys:"Ctrl+S",cid:"saveBtn",events:{click(e,t){app.editableGrid.sync({url:xpath,success(){Wb.tipDone(Str.save)}})}}}]}},{cname:"title",title:"Database
