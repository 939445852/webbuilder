    l=t.full_name;if(l==null)return"";else return"Avg: "+a.formatValue(e/l)},text:"Salary",align:"right",type:"usd",cid:"salaryCol",titleAlign:"right"},{cname:"column",checkBox:"int",fieldName:"checked",checkRefresh:true,cid:"checkCol1",menuText:"Check"},{cname:"column",checkBox:"roTrue",cid:"checkCol2",fieldName:"checked"},{cname:"column",checkBox:"roAll",cid:"checkCol3",fieldName:"checked"},{cname:"column",width:"5em",text:"Toggle",render(e,t,a,i){let
