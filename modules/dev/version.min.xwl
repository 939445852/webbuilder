_expanded: true
_icon: module
cls: Wb.Module
events:
  initialize: Wb.apply(app,{checkOut(){let e=app.grid1.selections;if(!e.length){Wb.tipSelect();return}Wb.confirm(Wb.getActionHint(e,"file_path",Str.checkOut),(t=>{Wb.ajax({url:xpath+"/check-out",params:{ids:e.map((e=>e.data.sid))},success(){Wb.tipDone(Str.checkOut)}})})).showBy(app.checkOutBtn,"br")},load(){app.grid1.delayLoad({comps:app.viewport1.tbar})}});Wb.make(app,{cname:"window",icon:"undo",layout:"grid1",dialog:true,title:Str.back,cid:"backWin",events:{ok(e){let
    t=app.versionSelect.value;Wb.confirm(Str.actionConfirm.format(Str.back,t),(e=>{Wb.ajax({url:xpath+"/rollback",params:{version:t},success(){app.backWin.close()}})}))}},items:[{cname:"select",text:Str.version,editable:false,required:true,url:xpath+"/select-version",cid:"versionSelect"}]});Wb.make(app,{cname:"viewport",layout:"fit",cid:"viewport1",tbar:{cname:"toolbar",items:[{icon:"logout",text:Str.checkOut,keys:"Ctrl+E",cid:"checkOutBtn",events:{click(e,t){app.checkOut()}}},{icon:"undo",cid:"backBtn",text:Str.back,events:{click(e,t){app.backWin.show()}}},{cname:"divider",cid:"divider1"},{icon:"delete",text:Str.del,keys:"Ctrl+D",cid:"delBtn",events:{click(e,t){app.grid1.removeRecords(xpath+"/del","file_path")}}},{cname:"divider",cid:"divider2"},{cname:"select",width:"8em",clearButton:true,placeholder:Str.version,editable:false,url:xpath+"/select-version",cid:"searchVersion",events:{clearclick(e){app.load()},select(e,t,c,a){app.load()}}},{cname:"text",minWidth:"5em",clearButton:true,placeholder:Str.search,flex:1,cid:"searchFile",maxWidth:"20em",events:{change(e,t,c){app.load()}}}]},items:[{cname:"grid",columnsSortable:true,sorters:{name:"sdate",desc:true},keyFields:"sid",url:xpath+"/select",cid:"grid1",multiSelect:true}]});
hideInMenu: 'false'
icon: form
img: ''
properties:
  cid: module
  remark: File version management
tags: ''
text: module
title: '@versionMng'
