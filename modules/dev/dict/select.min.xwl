_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
properties:
  cid: module
  remark: Select dictionary items
  serverScript: function main(){let e="select * from wb_dict",r=[];if(Params.search){Wb.setLike("search");r.push(`(name
    like {?search?} or alias like {?search?} or title like {?search?})`)}if(Params.searchGroup){Wb.setLike("searchGroup");r.push(`group_name
    like {?searchGroup?}`)}if(Params.searchContent){Wb.setLike("searchContent");r.push(`(validate_script
    like {?searchContent?} or edit_tags like {?searchContent?}\n      or render_script
    like {?searchContent?} or column_tags like {?searchContent?})`)}if(r.length){e+="
    where "+r.join(" and ")}e+=Wb.getOrderSql();Wb.sendDict(e,"wb,")}main();
tags: ''
text: module
title: ''
