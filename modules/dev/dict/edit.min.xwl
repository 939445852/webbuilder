  cid: module
  remark: Edit dictionary item
  serverScript: function main(){const a=Wb.load("./util.mjs");let e=Wb.getAllRows("select
    name,alias,group_name from wb_dict where sid={?$sid?}");a.checkDuplicate(Params.name??Params.oldName,Params.group_name??Params.oldGroup,Params.$sid);Wb.sync({tableName:"wb_dict",update:Params});a.clearBuffer(e);a.updateBuffer(true)}main();
