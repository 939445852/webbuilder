_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
properties:
  cid: module
  remark: Rollback to the specified version
  serverScript: |-
    Wb.checkDemo();
    function main() {
      Wb.sql({
        sql: 'select file_path,file_content from wb_version where file_version={?version?}',
        blob: true,
        fn(row) {
          new Wb.File(true, row.file_path).stream = row.file_content;
        }
      });
    }
    main();
tags: ''
text: module
title: ''
