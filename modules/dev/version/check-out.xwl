_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
properties:
  cid: module
  remark: Check out files
  serverScript: |-
    Wb.checkDemo();
    function main() {
      let sqlMap = Wb.Query.getArraySql(Wb.getObject('ids'), 'varchar');

      Wb.sql({
        sql: 'select file_path,file_content from wb_version where sid in (' + sqlMap.sql + ')',
        params: sqlMap.params,
        blob: true,
        fn(row) {
          new Wb.File(true, row.file_path).stream = row.file_content;
        }
      });
    }
    main();
tags: ''
text: module
title: ''
