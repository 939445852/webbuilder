_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
properties:
  cid: module
  remark: Get starting form
  serverScript: |-
    function main() {
      const Util = Wb.load('./util.mjs');
      let flow = new Wb.Workflow({ file: Params.file });
      Wb.send({ form: Util.getForm(flow, 'start') });
    }
    main();
tags: ''
text: module
title: ''
