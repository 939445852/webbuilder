cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
properties:
  cid: module
  remark: Select users
  serverScript: function main(){let e="";if(Params.query){Wb.setLike("query");e="and
    (user_name like {?query?} or display_name like {?query?})"}Wb.sendRows(`select
    sid,user_name,display_name from wb_user where status=1 ${e} order by user_name`)}main();
