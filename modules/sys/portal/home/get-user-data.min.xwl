_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
properties:
  cid: module
  remark: Get current user data
  serverScript: function main(){const e=Wb.UserUtil.protectedText;let s;s=`select
    '${e}' as password, '${e}' as confirm_password, display_name, create_date,\n    login_times,
    email, mobile_phone, use_lang from wb_user where sid={?sys.userid?}`;Wb.sendDict(s,"wb,")}main();
tags: ''
text: module
title: ''
