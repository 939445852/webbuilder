  serverScript: function main(){const a=Wb.load("./util.mjs");let t={array:true};if(Wb.getBool("blob"))t.blob="text";Wb.sendSql(Wb.apply(t,{sql:Wb.decodeBase64(Params.data),db:Params.db,returnObject:true,readonly:true,dateFormat:true,rs:a.maxRows}))}main();
