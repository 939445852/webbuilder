cls: Wb.Module
hideInMenu: 'false'
icon: ''
img: ''
properties:
  cid: module
  remark: Select department manager
  serverScript: function main(){let e;e="select sid as manager_id,user_name as manager_user,display_name
    as manager_name from wb_user";if(Params.query){Wb.setLike("query");e+=" where
    (user_name like {?query?} or display_name like {?query?})"}e+=" order by display_name";Wb.sendRows(e)}main();
