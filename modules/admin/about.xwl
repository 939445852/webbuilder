  text: viewport1
properties:
  cid: module
  obfuscate: 'true'
  remark: View about WebBuilder
  serverScript: |-
    function main() {
      const Util = Wb.load('wb/modules/sys/portal/home/util.mjs');
      let lic = Util.getLicensee();

      Wb.set({
        version: Wb.getConfig('sys.app.version'),
        type: Wb.getConfig('sys.app.type'),
        date: Wb.getConfig('sys.app.date').dateText,
        serverCode: Config.serverCode,
        lic: (lic ? ('Authorized to ' + lic) : 'Unlicensed')
      });
    }
    main();
tags: ''
text: module
title: '@about'
