_expanded: true
_icon: module
cls: Wb.Module
hideInMenu: 'false'
icon: info
img: ''
items:
- _expanded: true
  _icon: viewport
  cls: Wb.Viewport
  events:
    ready: |-
      let el = this.el, mainDiv, teamDiv, updateLink, newVersion;

      if (Str.lang == 'zh-cn')
        mainDiv = el.query('[cid=lang-zh-cn]');
      else
        mainDiv = el.query('[cid=lang-en]');
      mainDiv.setStyle('display', 'block');
      teamDiv = mainDiv.query('[cid=team-list]')
      teamDiv.addEventListener('animationend', f => {
        teamDiv.parentNode.cls = 'w-scroll-true';
      }, {
        once: true
      });
      teamDiv.className = 'w-vscroll';
      new Wb.Button({
        el: mainDiv.query('[cid=buy]'), icon: 'cart', text: Str.buy, type: 'primary', owner: this, handler() {
          window.open('https://www.geejing.com/buy');
        }
      });
      newVersion = mainDiv.query('[cid=newVersion]');
      Wb.ajax({
        url: xpath + '/get-new-version', mask: false, showError: false,
        failure(resp) {
          newVersion.textContent = Str.unableDetectNew;
        },
        success(resp) {
          if (parseFloat(resp) != _$version$_) {
            newVersion.textContent = '';
            updateLink = newVersion.addTag('a');
            updateLink.href = 'https://www.geejing.com/download';
            updateLink.target = '_blank';
            updateLink.textContent = Str.foundNewVersion.format(resp);
            updateLink.highlight();
          } else {
            newVersion.textContent = Str.alreadyLatestVersion;
          }
        }
      });
  properties:
    autoScroll: 'true'
    cid: viewport1
    html: |-
      <div cid='lang-en' class='w-html' style='line-height:2;display:none;'>
        <h2>About WebBuilder</h2>
        <hr class="w-hr">
        <table>
          <tr>
            <td rowspan="6">
              <div class="w-icon icon-geejing" style="margin:.3em;font-size:3em;"></div>
            </td>
            <td>WebBuilder _$type$_, Date: _$date$_</td>
          </tr>
          <tr>
            <td>Version:
              _$version$_
              (<span cid="newVersion"><div class="w-icon w-spin icon-loading w-block"></div> Detecting new version...</span>)
            </td>
          </tr>
          <tr>
            <td>_$lic$_</td>
          </tr>
          <tr>
            <td>Powerful rapid application development and runtime platform</td>
          </tr>
          <tr>
            <td>Server Code: _$serverCode$_</td>
          </tr>
          <tr>
            <td class='w-padding-tb'>
              <div cid='buy'></div>
            </td>
