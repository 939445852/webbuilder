properties:
  cid: module
  remark: Delete tasks
  serverScript: |-
    function main() {
      let del = Wb.getObject('del');

      del.forEach(item => JobUtil.stopJob(item.$sid));
      Wb.sync({ tableName: 'wb_job', del });
    }
    main();
